<style>
  .chapter li.chapter-item.hide-article-children > ol.section {
    display: none !important;
  }
</style>
<script>
  (function() {
    function hideArticleChildren(root) {
      const scope = root || document;
      const links = scope.querySelectorAll('.chapter a[href$="articles/index.html"]');
      for (const link of links) {
        const wrapper = link.closest('.chapter-link-wrapper');
        const item = wrapper && wrapper.parentElement;
        if (!item || !item.classList.contains('chapter-item')) {
          continue;
        }
        item.classList.add('hide-article-children');
      }
    }

    function init() {
      hideArticleChildren(document);

      const observer = new MutationObserver(function() {
        hideArticleChildren(document);
      });

      observer.observe(document.documentElement, {
        childList: true,
        subtree: true
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>
